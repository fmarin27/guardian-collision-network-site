  // =========================
  // notify manager
  // =========================
  function extractNotesStructured(lines: string[]) {
    const out: any = {};
    const free: string[] = [];

    for (const raw of lines || []) {
      const line = String(raw || "").trim();
      if (!line) continue;

      // Pattern: "Section: key=value" or "Section: value"
      const m = line.match(/^([^:]{2,40}):\s*(.+)$/);
      if (m) {
        const section = m[1].trim().toLowerCase().replace(/\s+/g, "_");
        const rest = m[2].trim();

        // key=value pairs inside rest
        const kv = rest.match(/^([a-z0-9_ -]{2,40})\s*=\s*(.+)$/i);
        if (kv) {
          const key = kv[1].trim().toLowerCase().replace(/\s+/g, "_");
          const val = kv[2].trim();
          out[section] = out[section] || {};
          out[section][key] = val;
        } else {
          out[section] = out[section] ?? [];
          if (Array.isArray(out[section])) out[section].push(rest);
          else out[section] = rest;
        }
        continue;
      }

      free.push(line);
    }

    if (free.length) out.freeText = free;
    return out;
  }

  async function notifyManagerOnce() {
    if (notifiedRef.current) return;
    notifiedRef.current = true;

    try {
      const answers = {
        // basics
        customerName,
        callbackNumber,
        intent,
        mode,
        step,

        // estimate intake
        helpSummary,
        haveVin,
        vinValue,
        havePhotos,
        notes: extraNotes,

        // forms
        formsClaimType,
        formsDeliveryChoice,
        authForm: mode === "forms" ? { ...authForm, signatureDataUrl: authForm.signatureDataUrl ? "[captured]" : "" } : undefined,
        dtpForm: mode === "forms" ? dtpForm : undefined,
        drForm: mode === "forms" ? drForm : undefined,
        estForm: mode === "forms" ? estForm : undefined,
      };

      const payload = {
        createdAt: new Date().toISOString(),
        sessionId: sessionIdRef.current,
        branch: mode,
        intent,
        step,
        answers,
        extracted: extractNotesStructured(extraNotes),
        uploadsCount: uploads.length,
        uploadNames: uploads.map((f) => f.name),
        skippedUploads: uploads.length === 0,
      };

      const fd = new FormData();
      fd.append("payload", JSON.stringify(payload));

      // Attach files (cap total size to avoid SMTP limits like Gmail's ~25MB)
      const MAX_TOTAL = 20 * 1024 * 1024; // 20MB
      let total = 0;

      for (const f of uploads) {
        if (!f) continue;
        if (total + f.size > MAX_TOTAL) continue;
        total += f.size;
        fd.append("files", f, f.name);
      }

      const res = await fetch("/api/concierge/notify", {
        method: "POST",
        body: fd,
      });

      if (!res.ok) {
        const t = await res.text().catch(() => "");
        throw new Error(`Notify failed (${res.status}): ${t}`);
      }
    } catch (err) {
      console.error("notifyManagerOnce error", err);
      // allow retry if needed
      notifiedRef.current = false;
    }
  }

