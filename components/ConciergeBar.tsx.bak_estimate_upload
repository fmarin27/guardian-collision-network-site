  function interpretHavePhotosAnswer(text: string): "yes" | "no" | "maybe" | "unknown" {
    const t = text.trim().toLowerCase();

    const saysLater =
      t.includes("not yet") ||
      t.includes("later") ||
      t.includes("soon") ||
      t.includes("todavia no") ||
      t.includes("todavía no") ||
      t.includes("más tarde") ||
