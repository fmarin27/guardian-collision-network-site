      t === "ya" ||
      t.includes("yeah") ||
      t.includes("yea") ||
      t.includes("yep") ||
      t.includes("sure") ||
      t.includes("i do") ||
      t.includes("i have") ||
      t.includes("got") ||
      t.includes("have them") ||
      t === "si" ||
      t === "sí" ||
