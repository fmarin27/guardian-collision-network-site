  async function submitRepairAuthorization() {
    setAuthError(null);

    const cleanedPhone = normalizePhone(authForm.phone);
    const phoneOk = cleanedPhone.length === 10 || (cleanedPhone.length === 11 && cleanedPhone.startsWith("1"));

    if (!authForm.fullName.trim()) return setAuthError("Please enter your name.");
    if (!phoneOk) return setAuthError("Please enter a valid phone number.");
    if (!authExplained) return setAuthError('Please click "Click here: Please read first" before agreeing.');
    if (!authForm.agree) return setAuthError("Please check the authorization box.");
    if (!sigHasInkRef.current || !authForm.signatureDataUrl) return setAuthError("Please sign in the signature box.");

    setAuthSubmitting(true);
    try {
      const payload = {
        sessionId: sessionIdRef.current,
        claimType: formsClaimType,
        form: {
          ...authForm,
          phone: formatPhone(cleanedPhone),
        },
      };

      const res = await fetch("/api/forms/authorization", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const t = await res.text().catch(() => "");
        throw new Error(t || "Failed to generate PDF.");
      }

      const blob = await res.blob();
      const filename = `UAB-Repair-Authorization-${slugifyFileName(authForm.fullName)}-${yyyyMmDd()}.pdf`;
      downloadBlob(blob, filename);

      addMessage("bot", "Done ✅ Your signed authorization was generated and downloaded.");

      if (formsClaimType === "insurance") {
        setFormsPdfIndex(0);
        addMessage("bot", `Next — ${INSURANCE_FORMS[0].title}. Fill it out below, then click Done.`);
        setStep("forms_pdf");
      } else {
        addMessage("bot", "Next — any notes for the shop? (Optional — type “skip”)");
        setStep("forms_notes");
      }
    } catch (e: any) {
      setAuthError(e?.message || "Something went wrong generating the PDF.");
    } finally {
      setAuthSubmitting(false);
    }
  }

