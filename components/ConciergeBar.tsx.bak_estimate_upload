  async function submitCurrentInsuranceForm() {
    setInsuranceError(null);

    if (formsPdfIndex >= INSURANCE_FORMS.length) return;

    const current = INSURANCE_FORMS[formsPdfIndex];
    const key = current.key as InsuranceFormKey;

    // Must expand "What is this?" at least once
    if (!insuranceExplained[key]) {
      return setInsuranceError('Please click "What is this?" and review the form explanation before agreeing.');
    }

    // Must have signature on file
    if (!authForm.signatureDataUrl) {
      return setInsuranceError("Missing signature. Please complete the Repair Authorization signature first.");
    }

    // Validation + payload per form
    let kind: "direction_to_pay" | "designated_representative" | "estimate_dismantling" = current.kind;
    let form: any = null;
    let filenameBase = "";

    if (kind === "direction_to_pay") {
      if (!dtpForm.fullName.trim()) return setInsuranceError("Please enter your name.");
      if (!dtpForm.insurerName.trim()) return setInsuranceError("Please enter the insurance company name.");
      if (!dtpForm.year.trim() || !dtpForm.make.trim() || !dtpForm.model.trim())
        return setInsuranceError("Please enter the vehicle year, make, and model.");
      if (!dtpForm.agree) return setInsuranceError("Please check the agreement box.");
      form = { ...dtpForm, signatureDataUrl: authForm.signatureDataUrl };
      filenameBase = "UAB-Direction-to-Pay";
    }

    if (kind === "designated_representative") {
      if (!drForm.fullName.trim()) return setInsuranceError("Please enter your name.");
      if (!drForm.insurerName.trim()) return setInsuranceError("Please enter the insurance company name.");
      if (!drForm.year.trim() || !drForm.make.trim() || !drForm.model.trim())
        return setInsuranceError("Please enter the vehicle year, make, and model.");
      if (!drForm.agree) return setInsuranceError("Please check the agreement box.");
      form = { ...drForm, signatureDataUrl: authForm.signatureDataUrl };
      filenameBase = "UAB-Designated-Representative";
    }

    if (kind === "estimate_dismantling") {
      if (!estForm.fullName.trim()) return setInsuranceError("Please enter your name.");
      if (!estForm.year.trim() || !estForm.make.trim() || !estForm.model.trim())
