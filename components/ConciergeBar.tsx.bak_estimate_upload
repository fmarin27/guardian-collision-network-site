      form = { ...estForm, signatureDataUrl: authForm.signatureDataUrl };
      filenameBase = "UAB-Authorization-Estimate-Dismantling";
    }

    setInsuranceSubmitting(true);
    try {
      const payload = {
        sessionId: sessionIdRef.current,
        claimType: formsClaimType,
        kind,
        form,
      };

      const res = await fetch("/api/forms/authorization", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
