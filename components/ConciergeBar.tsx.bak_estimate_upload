  | "accident_photosTaken"
  | "accident_fullCoverage"
  | "accident_contactedInsurance"
  | "accident_shopRep"
  // estimate branch
  | "estimate_haveVin"
  | "estimate_vinValue"
  | "estimate_havePhotos"
  | "estimate_damageHow"
  | "estimate_upload"
  // forms branch
  | "forms_claimType"
  | "forms_delivery"
  | "forms_auth" // Repair Authorization web form
  | "forms_pdf" // remaining fillable PDFs (insurance)
  | "forms_notes"
  | "forms_complete"
  // common
  | "callback_number"
  | "done";

