                              <div className="text-xs text-white/60 mb-1">Vehicle make</div>
                              <input
                                value={drForm.make}
                                onChange={(e) => setDrForm((p) => ({ ...p, make: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Make"
                              />
                            </div>

                            <div className="sm:col-span-2">
                              <div className="text-xs text-white/60 mb-1">Vehicle model</div>
                              <input
                                value={drForm.model}
                                onChange={(e) => setDrForm((p) => ({ ...p, model: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Model"
                              />
                            </div>

                            <div className="sm:col-span-2">
                              <div className="text-xs text-white/60 mb-1">Plate # (optional)</div>
                              <input
                                value={drForm.plate}
                                onChange={(e) => setDrForm((p) => ({ ...p, plate: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Plate"
                              />
                            </div>
                          </div>
                        )}

                        {currentInsuranceForm.kind === "estimate_dismantling" && (
                          <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div className="sm:col-span-2">
                              <div className="text-xs text-white/60 mb-1">Customer name</div>
                              <input
                                value={estForm.fullName}
                                onChange={(e) => setEstForm((p) => ({ ...p, fullName: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Full name"
                              />
                            </div>

                            <div>
                              <div className="text-xs text-white/60 mb-1">Vehicle year</div>
                              <input
                                value={estForm.year}
                                onChange={(e) => setEstForm((p) => ({ ...p, year: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="YYYY"
                              />
                            </div>

                            <div>
                              <div className="text-xs text-white/60 mb-1">Vehicle make</div>
                              <input
                                value={estForm.make}
                                onChange={(e) => setEstForm((p) => ({ ...p, make: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Make"
                              />
                            </div>

                            <div className="sm:col-span-2">
                              <div className="text-xs text-white/60 mb-1">Vehicle model</div>
                              <input
                                value={estForm.model}
                                onChange={(e) => setEstForm((p) => ({ ...p, model: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Model"
                              />
                            </div>

                            <div className="sm:col-span-2">
                              <div className="text-xs text-white/60 mb-1">Plate # (optional)</div>
                              <input
                                value={estForm.plate}
                                onChange={(e) => setEstForm((p) => ({ ...p, plate: e.target.value }))}
                                className="w-full rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-yellow-400/30"
                                placeholder="Plate"
                              />
                            </div>
                          </div>
                        )}

                        {/* Signature preview */}
                        <div className="rounded-2xl border border-white/10 bg-black/20 p-3">
                          <div className="text-xs text-white/70 font-medium">Signature on file</div>
                          <div className="text-[11px] text-white/50">
                            We’ll apply your signature from the Repair Authorization to this form.
                          </div>

                          <div className="mt-2 flex items-center gap-3">
                            {authForm.signatureDataUrl ? (
                              <img
                                src={authForm.signatureDataUrl}
                                alt="Signature"
                                className="h-12 w-auto max-w-full rounded-md bg-white p-1"
                              />
                            ) : (
                              <div className="text-[11px] text-red-200">No signature found.</div>
                            )}

                            <div className="text-[11px] text-white/50">
                              Date: <span className="text-white/70">{yyyyMmDd()}</span>
                            </div>
                          </div>
                        </div>

                        {/* Agreement */}
                        <div className="space-y-2">
                          {currentInsuranceForm.kind === "direction_to_pay" && (
                            <label className="flex items-start gap-2 text-xs text-white/80">
                              <input
                                type="checkbox"
                                disabled={!insuranceExplained.direction_to_pay}
                                checked={dtpForm.agree}
                                onChange={(e) => setDtpForm((p) => ({ ...p, agree: e.target.checked }))}
                                className="mt-0.5"
                              />
                              <span>
                                I understand and agree — and I authorize Ultimate Auto Body to apply my Repair Authorization signature
                                to this form.
                              </span>
                            </label>
                          )}

                          {currentInsuranceForm.kind === "designated_representative" && (
                            <label className="flex items-start gap-2 text-xs text-white/80">
                              <input
                                type="checkbox"
                                disabled={!insuranceExplained.designated_representative}
                                checked={drForm.agree}
                                onChange={(e) => setDrForm((p) => ({ ...p, agree: e.target.checked }))}
                                className="mt-0.5"
                              />
                              <span>
                                I understand and agree — and I authorize Ultimate Auto Body to apply my Repair Authorization signature
                                to this form.
                              </span>
                            </label>
                          )}

                          {currentInsuranceForm.kind === "estimate_dismantling" && (
                            <>
                              <label className="flex items-start gap-2 text-xs text-white/80">
                                <input
                                  type="checkbox"
                                  disabled={!insuranceExplained.estimate_dismantling}
                                  checked={estForm.agree}
                                  onChange={(e) => setEstForm((p) => ({ ...p, agree: e.target.checked }))}
                                  className="mt-0.5"
                                />
                                <span>
                                  I understand and agree — and I authorize Ultimate Auto Body to apply my Repair Authorization signature
                                  to this form.
                                </span>
                              </label>

                              <label className="flex items-start gap-2 text-xs text-white/80">
                                <input
                                  type="checkbox"
                                  disabled={!insuranceExplained.estimate_dismantling}
                                  checked={estForm.notRepairAgree}
                                  onChange={(e) => setEstForm((p) => ({ ...p, notRepairAgree: e.target.checked }))}
                                  className="mt-0.5"
                                />
                                <span>I understand this authorizes an estimate/dismantling only — it is NOT an authorization to repair.</span>
                              </label>
                            </>
                          )}
                        </div>

                        {insuranceError && (
                          <div className="rounded-xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
                            {insuranceError}
                          </div>
                        )}

                        <div className="flex items-center justify-end gap-2 pt-1">
                          <button
                            type="button"
                            disabled={insuranceSubmitting}
                            onClick={submitCurrentInsuranceForm}
                            className="rounded-xl border border-yellow-400/40 bg-yellow-400/10 px-4 py-2 text-xs text-white hover:border-yellow-300 hover:bg-yellow-400/20 transition disabled:opacity-60"
                          >
                            {insuranceSubmitting ? "Generating…" : "Generate & Download"}
                          </button>
                        </div>
                      </>
                    ) : (
                      <>
                        <div className="flex items-start justify-between gap-3">
                          <div>
                            <div className="text-sm text-white font-medium">All set ✅</div>
                            <div className="text-xs text-white/60">
                              You finished the insurance forms. Want the full packet too?
                            </div>
                          </div>

                          <div className="flex gap-2">
                            <button
                              type="button"
                              onClick={() => openInNewTab(INSURANCE_PACKET_BLANK_URL)}
                              className="rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-xs text-white/80 hover:bg-white/10 transition"
                            >
                              Blank packet
                            </button>
                          </div>
                        </div>

                        <div className="flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-2 pt-1">
                          <button
                            type="button"
                            disabled={insuranceSubmitting}
                            onClick={downloadFullPacketAll4}
                            className="rounded-xl border border-yellow-400/40 bg-yellow-400/10 px-4 py-2 text-xs text-white hover:border-yellow-300 hover:bg-yellow-400/20 transition disabled:opacity-60"
                          >
                            {insuranceSubmitting ? "Generating…" : "Download full packet (All 4)"}
                          </button>

                          <button
                            type="button"
                            onClick={continueToNotes}
                            className="rounded-xl border border-yellow-400/40 px-4 py-2 text-xs text-white hover:border-yellow-300 hover:bg-yellow-400/20 transition"
                          >
                            Continue
                          </button>
                        </div>

                        {insuranceError && (
                          <div className="rounded-xl border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
                            {insuranceError}
                          </div>
                        )}
                      </>
                    )}
                  </div>
                )}

                {/* Upload Panel (estimate flow only) */}
                {showUploadPanel && (
                  <div className="rounded-2xl border border-white/10 bg-black/30 p-4 space-y-3">
                    <div className="flex items-start justify-between gap-3">
                      <div>
                        <div className="text-sm text-white font-medium">Upload photos or documents (optional)</div>
                        <div className="text-xs text-white/60">Photos are best, but you can also upload PDFs or other files.</div>
                      </div>

                      <div className="flex gap-2">
                        <button
                          type="button"
                          onClick={() => fileInputRef.current?.click()}
                          className="rounded-xl border border-yellow-400/40 bg-yellow-400/10 px-4 py-2 text-xs text-white hover:border-yellow-300/60 transition"
                        >
                          Add files
                        </button>
                        <input
                          ref={fileInputRef}
                          type="file"
                          multiple
                          accept="*/*"
                          onChange={handleFilesChosen}
                          className="hidden"
                        />
                      </div>
                    </div>

                    {uploads.length > 0 && (
                      <div className="grid grid-cols-3 sm:grid-cols-4 gap-2">
                        {uploads.map((f, idx) => (
                          <div key={`${f.name}-${idx}`} className="relative rounded-xl overflow-hidden border border-white/10 bg-black/40">
                            {f.type?.startsWith("image/") ? (
                              <>
                                {/* eslint-disable-next-line @next/next/no-img-element */}
                                <img
                                  src={URL.createObjectURL(f)}
                                  alt={f.name}
                                  className="h-24 w-full object-cover"
                                  onLoad={(e) => {
                                    const src = (e.currentTarget as HTMLImageElement).src;
                                    setTimeout(() => URL.revokeObjectURL(src), 1500);
                                  }}
                                />
                              </>
                            ) : (
                              <div className="h-24 w-full flex flex-col items-center justify-center gap-1 p-2 text-center">
                                <div className="text-[10px] text-white/80 break-words">{f.name}</div>
                                <div className="text-[9px] text-white/45">{f.type || "file"}</div>
                              </div>
                            )}
<button
                              type="button"
                              onClick={() => removeUpload(idx)}
                              className="absolute top-1 right-1 rounded-full border border-white/20 bg-black/70 px-2 py-1 text-[10px] text-white hover:bg-black transition"
                              aria-label={`Remove ${f.name}`}
                            >
                              ✕
                            </button>
                          </div>
                        ))}
                      </div>
                    )}

                    <div className="flex items-center justify-end gap-2 pt-1">
                      <button
                        type="button"
                        onClick={skipUpload}
                        className="rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-xs text-white/80 hover:bg-white/10 transition"
                      >
                        Skip
                      </button>
                      <button
                        type="button"
                        onClick={continueFromUpload}
                        className="rounded-xl border border-yellow-400/60 bg-yellow-400/15 px-4 py-2 text-xs font-semibold text-white hover:border-yellow-300 hover:bg-yellow-400/20 transition"
                      >
                        Continue
                      </button>
                    </div>
                  </div>
                )}
              </div>

              {/* ✅ Footer stays visible (so Send button never gets cut off either) */}
              <div className="flex-shrink-0 border-t border-white/10 px-5 py-4 bg-black/80">

<div className="flex gap-2">

  <input
    value={input}
    onChange={(e) => setInput(e.target.value)}
    onKeyDown={(e) => !inputDisabled && e.key === "Enter" && send()}
    placeholder={placeholder}
    disabled={inputDisabled}
    className="flex-1 rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-sm text-white outline-none focus:border-yellow-400/60"
  />
  <button
    type="button"
    onClick={send}
    disabled={inputDisabled}
    className="rounded-xl border border-yellow-400/60 bg-yellow-400/15 px-4 py-3 text-sm font-semibold text-white hover:border-yellow-300 hover:bg-yellow-400/20 transition disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Send
  </button>
</div>

                <div className="mt-2 text-[11px] text-white/45">
                  {mode === "forms"
                    ? "Tip: In the insurance flow, after Repair Authorization you’ll be guided through the other 3 forms."
                    : "Tip: Upload photos if you have them — it speeds things up."}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </>
  );
}
