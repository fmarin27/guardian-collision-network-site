  async function downloadFullPacketAll4() {
    setInsuranceError(null);

    if (!authForm.signatureDataUrl) {
      return setInsuranceError("Missing signature. Please complete the Repair Authorization signature first.");
    }

    setInsuranceSubmitting(true);
    try {
      const payload = {
        sessionId: sessionIdRef.current,
        claimType: formsClaimType,
        kind: "packet_all_4",
        packet: {
          repairAuth: {
            ...authForm,
            phone: formatPhone(normalizePhone(authForm.phone)),
          },
          dtp: { ...dtpForm, signatureDataUrl: authForm.signatureDataUrl },
          dr: { ...drForm, signatureDataUrl: authForm.signatureDataUrl },
          est: { ...estForm, signatureDataUrl: authForm.signatureDataUrl },
        },
      };

      const res = await fetch("/api/forms/authorization", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const t = await res.text().catch(() => "");
        throw new Error(t || "Failed to generate PDF.");
      }

      const blob = await res.blob();
      const filename = `UAB-Forms-Packet-All-4-${slugifyFileName(authForm.fullName)}-${yyyyMmDd()}.pdf`;
      downloadBlob(blob, filename);

      addMessage("bot", "Done ✅ Full packet downloaded.");
