function parseYesNoNotSure(text: string): "yes" | "no" | "not_sure" | "unknown" {
  const t = text.trim().toLowerCase();

  // YES (English + Spanish)
  if (
    t === "y" ||
    t === "yes" ||
    t === "yeah" ||
    t === "yea" ||
    t === "yep" ||
    t === "sure" ||
    t === "si" ||
    t === "sí" ||
    t === "s" ||
    t === "claro" ||
    t === "seguro" ||
    t.includes("yes") ||
    t.includes("sí") ||
    t.includes("si ")
  )
    return "yes";

  // NO (English + Spanish)
  if (
    t === "n" ||
    t === "no" ||
    t === "nope" ||
    t === "nop" ||
    t.includes("not really") ||
    t.includes("dont") ||
    t.includes("don't") ||
    t.includes("para nada") ||
    t.includes("no realmente")
  )
    return "no";

  // NOT SURE (English + Spanish)
  if (
    t.includes("not sure") ||
    t.includes("unsure") ||
    t.includes("maybe") ||
    t.includes("kinda") ||
    t.includes("no se") ||
    t.includes("no sé") ||
    t.includes("no estoy seguro") ||
    t.includes("no estoy segura") ||
    t.includes("tal vez") ||
    t.includes("quizas") ||
    t.includes("quizás")
  )
    return "not_sure";

  return "unknown";
}

function detectIntent(text: string): Intent {
    const t = text.toLowerCase();

