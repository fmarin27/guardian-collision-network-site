function makeSessionId() {
  return typeof crypto !== "undefined" && "randomUUID" in crypto
    ? crypto.randomUUID()
    : `sess_${Date.now()}_${Math.random().toString(16).slice(2)}`;
}

function normalizePhone(text: string) {
  return text.replace(/\D/g, "");
}

function formatPhone(digits: string) {
  if (digits.length === 10) return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
  if (digits.length === 11 && digits.startsWith("1")) {
    const d = digits.slice(1);
    return `(${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6)}`;
  }
  return digits;
}

function downloadBlob(blob: Blob, filename: string) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1500);
}

function slugifyFileName(s: string) {
  return s
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

function yyyyMmDd(d = new Date()) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

export default function ConciergeBar() {
  const { lang, tr } = useLang();
  const [open, setOpen] = useState(false);

  // Mode routing
  const [mode, setMode] = useState<ConciergeMode>("default");

  // Branch + step
  const [intent, setIntent] = useState<Intent>("other");
  const [step, setStep] = useState<Step>("help");

  // --- Language switching (mid-conversation) ---
  const prevLangRef = useRef<Lang>(lang);

  const promptForStep = useCallback(
    (s: Step) => {
      switch (s) {
        case "help":
          return tr(
            "Hey! 👋 How can we help you today?",
            "¡Hola! 👋 ¿Cómo podemos ayudarte hoy?"
          );
        case "estimate_haveVin":
          return tr(
            "Do you have the VIN? (Typing it or a photo works.)",
            "¿Tienes el VIN? (Puedes escribirlo o subir una foto.)"
          );
        case "estimate_havePhotos":
          return tr(
            "Do you have photos of the damage you can share?",
            "¿Tienes fotos del daño que puedas compartir?"
          );
        case "estimate_damageHow":
          return tr(
            "Can you briefly tell me how the damage happened? (Type “skip” to skip.)",
            "¿Puedes decirme brevemente cómo ocurrió el daño? (Escribe “saltar” para omitir.)"
          );
        default:
          return tr("Continuing…", "Continuando…");
      }
    },
    [tr]
  );

  useEffect(() => {
    if (prevLangRef.current === lang) return;
    prevLangRef.current = lang;

    // Show a small confirmation in the chat
    addMessage("bot", tr("Language updated.", "Idioma actualizado."));

    // Re-ask the current prompt in the new language so it works mid-chat
    const nextPrompt = promptForStep(step);

    setMessages((prev) => {
      const last = prev.slice().reverse().find((m) => m.from === "bot");
      if (last && typeof last.text === "string" && last.text.trim() === nextPrompt.trim()) {
        return prev;
      }
      return [...prev, { from: "bot", text: nextPrompt }];
    });
  }, [lang, step, tr, promptForStep]);

  const [input, setInput] = useState("");

  // local memory (estimate flow)
  const [customerName, setCustomerName] = useState("");
  const [helpSummary, setHelpSummary] = useState("");
  const [haveVin, setHaveVin] = useState<"yes" | "no" | "maybe" | "unknown">("unknown");
  const [vinValue, setVinValue] = useState("");
  const [havePhotos, setHavePhotos] = useState<"yes" | "no" | "maybe" | "unknown">("unknown");

  // forms memory
  const [formsClaimType, setFormsClaimType] = useState<FormsClaimType | null>(null);
  const [formsDeliveryChoice, setFormsDeliveryChoice] = useState<FormsDeliveryChoice>(null);
  const [formsPdfIndex, setFormsPdfIndex] = useState(0);

  const [authForm, setAuthForm] = useState<AuthFormData>({
    fullName: "",
    address: "",
    townCity: "",
    zip: "",
    phone: "",
    email: "",
    year: "",
    make: "",
    model: "",
    plate: "",
    agree: false,
    signatureDataUrl: "",
  });

  const [authSubmitting, setAuthSubmitting] = useState(false);
  const [authError, setAuthError] = useState<string | null>(null);

  // ✅ Repair Authorization "read first" gate
  const [authExplained, setAuthExplained] = useState(false);
  const [authInfoOpen, setAuthInfoOpen] = useState(false);

  // insurance web-forms (reuse signature)
  const [dtpForm, setDtpForm] = useState<DirectionToPayFormData>({
    date: yyyyMmDd(),
    fullName: "",
    insurerName: "",
    claimNumber: "",
    year: "",
    make: "",
    model: "",
    agree: false,
  });

  const [drForm, setDrForm] = useState<DesignatedRepFormData>({
    date: yyyyMmDd(),
    fullName: "",
    insurerName: "",
    claimNumber: "",
    year: "",
    make: "",
    model: "",
    plate: "",
    agree: false,
  });

  const [estForm, setEstForm] = useState<EstimateDismantleFormData>({
