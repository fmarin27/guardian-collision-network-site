    notRepairAgree: false,
  });

  const [insuranceExplained, setInsuranceExplained] = useState<Record<InsuranceFormKey, boolean>>({
    direction_to_pay: false,
    designated_representative: false,
    estimate_dismantling: false,
  });

  const [insuranceInfoOpen, setInsuranceInfoOpen] = useState<Record<InsuranceFormKey, boolean>>({
    direction_to_pay: false,
    designated_representative: false,
    estimate_dismantling: false,
  });

  const [insuranceSubmitting, setInsuranceSubmitting] = useState(false);
  const [insuranceError, setInsuranceError] = useState<string | null>(null);

  // signature pad
  const sigCanvasRef = useRef<HTMLCanvasElement | null>(null);
  const sigWrapRef = useRef<HTMLDivElement | null>(null);
  const sigDrawingRef = useRef(false);
  const sigLastRef = useRef<{ x: number; y: number } | null>(null);
  const sigHasInkRef = useRef(false);
  const [sigHasInk, setSigHasInk] = useState(false);

  // focus refs (nice UX)
  const fullNameRef = useRef<HTMLInputElement | null>(null);

  // extra notes
  const [extraNotes, setExtraNotes] = useState<string[]>([]);

  // callback info
  const [callbackNumber, setCallbackNumber] = useState("");

  // uploads
  const [uploads, setUploads] = useState<File[]>([]);
  const fileInputRef = useRef<HTMLInputElement | null>(null);
  const lastFilePickSigRef = useRef<string>("");

  const [messages, setMessages] = useState<Message[]>([{ from: "bot", text: tr("Hey! 👋 How can we help you today?", "¡Hola! 👋 ¿En qué podemos ayudarte hoy?") }]);

  // ✅ scroll the whole middle area (so forms never get clipped)
  const scrollBodyRef = useRef<HTMLDivElement | null>(null);

  // manager mode
  const [managerMode, setManagerMode] = useState(false);

  // handoff status (manager connection)
  const [handoffStage, setHandoffStage] = useState<"idle" | "connecting" | "busy">("idle");
  const handoffStageRef = useRef<"idle" | "connecting" | "busy">("idle");

  // notify guards
  const notifiedRef = useRef(false);
  const sessionIdRef = useRef<string>("");

  // mode switch (ask first)
  const [pendingMode, setPendingMode] = useState<ConciergeMode | null>(null);
  const prevStateRef = useRef<SavedChatState | null>(null);

  // =========================
  // init
  // =========================
  useEffect(() => {
    const params = new URLSearchParams(window.location.search);
    setManagerMode(params.get("manager") === "1");
    sessionIdRef.current = makeSessionId();
  }, []);

  // ✅ auto scroll to bottom (so user sees latest + form)
  useEffect(() => {
    if (!open) return;
    const el = scrollBodyRef.current;
    if (!el) return;
    el.scrollTop = el.scrollHeight;
  }, [messages, open, uploads, pendingMode, step, formsPdfIndex]);

  function addMessage(from: "bot" | "user", text: string) {
    setMessages((prev) => [...prev, { from, text }]);
  }

  function addBotOnce(text: string) {
    setMessages((prev) => {
      const last = prev[prev.length - 1];
      if (last && last.from === "bot" && last.text === text) return prev;
      return [...prev, { from: "bot", text }];
    });
  }

  // =========================
  // signature canvas init (responsive + white bg)
  // =========================
  useEffect(() => {
    if (step !== "forms_auth") return;

    const canvas = sigCanvasRef.current;
    const wrap = sigWrapRef.current;
    if (!canvas || !wrap) return;

    const setup = () => {
      const dpr = Math.max(1, Math.floor(window.devicePixelRatio || 1));
      const cssH = 170;

      const measuredW = Math.floor(wrap.clientWidth || 740);
      const cssW = Math.max(280, measuredW);

      canvas.style.width = "100%";
      canvas.style.height = `${cssH}px`;

      canvas.width = cssW * dpr;
      canvas.height = cssH * dpr;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      // White background (so black ink shows & export looks correct)
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, cssW, cssH);

      // pen
      ctx.lineWidth = 2.6;
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      ctx.strokeStyle = "#000000";

      sigHasInkRef.current = false;
      setSigHasInk(false);
      sigLastRef.current = null;

      setTimeout(() => fullNameRef.current?.focus(), 50);
    };

    setup();
    window.addEventListener("resize", setup);
    return () => window.removeEventListener("resize", setup);
  }, [step]);

  function getCanvasPoint(e: PointerEvent | React.PointerEvent) {
    const canvas = sigCanvasRef.current;
    if (!canvas) return null;
    const rect = canvas.getBoundingClientRect();
    const x = (("clientX" in e ? e.clientX : 0) - rect.left);
    const y = (("clientY" in e ? e.clientY : 0) - rect.top);
    return { x, y };
  }

  function sigStart(e: React.PointerEvent) {
    const canvas = sigCanvasRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;

    (e.currentTarget as HTMLCanvasElement).setPointerCapture(e.pointerId);
    sigDrawingRef.current = true;

    const p = getCanvasPoint(e);
    sigLastRef.current = p;

    if (p) {
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
    }
  }

  function sigMove(e: React.PointerEvent) {
    const canvas = sigCanvasRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx) return;
    if (!sigDrawingRef.current) return;

    const p = getCanvasPoint(e);
    const last = sigLastRef.current;
    if (!p || !last) return;

    ctx.lineTo(p.x, p.y);
    ctx.stroke();

    sigLastRef.current = p;

    if (!sigHasInkRef.current) {
      sigHasInkRef.current = true;
      setSigHasInk(true);
    }
  }

  function sigEnd() {
    sigDrawingRef.current = false;
    sigLastRef.current = null;

    const canvas = sigCanvasRef.current;
    if (!canvas) return;

    const dataUrl = canvas.toDataURL("image/png");
    setAuthForm((prev) => ({ ...prev, signatureDataUrl: dataUrl }));
  }

  function clearSignature() {
    const canvas = sigCanvasRef.current;
    const wrap = sigWrapRef.current;
    const ctx = canvas?.getContext("2d");
    if (!canvas || !ctx || !wrap) return;

    const dpr = Math.max(1, Math.floor(window.devicePixelRatio || 1));
    const cssH = 170;
    const cssW = Math.max(280, Math.floor(wrap.clientWidth || 740));

    // clear entire backing store
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // redraw white
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, cssW, cssH);

    // pen again
    ctx.lineWidth = 2.6;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.strokeStyle = "#000000";

    sigHasInkRef.current = false;
    setSigHasInk(false);
    setAuthForm((prev) => ({ ...prev, signatureDataUrl: "" }));
  }

  function close() {
    window.dispatchEvent(
      new CustomEvent("concierge:close", { detail: { source: "pill" } })
    );
    setOpen(false);
  }

  function isMidFlow() {
    const progressed = step !== "help";
    const hasData =
      customerName.trim().length > 0 ||
      helpSummary.trim().length > 0 ||
      uploads.length > 0 ||
      callbackNumber.trim().length > 0 ||
      extraNotes.length > 0 ||
      haveVin !== "unknown" ||
      havePhotos !== "unknown" ||
      vinValue.trim().length > 0 ||
      formsClaimType !== null ||
      formsDeliveryChoice !== null ||
      authForm.fullName.trim().length > 0 ||
      mode !== "default";
    return progressed || hasData;
  }

  function snapshotState(): SavedChatState {
    return {
      mode,
      intent,
      step,
      messages,

      customerName,
      helpSummary,

      haveVin,
      vinValue,
      havePhotos,

      formsClaimType,
      formsDeliveryChoice,
      formsPdfIndex,

      authForm,
      dtpForm,
      drForm,
      estForm,
      insuranceExplained,
      authExplained,

      extraNotes,
      callbackNumber,

      uploads,
      lastFilePickSig: lastFilePickSigRef.current,

      notified: notifiedRef.current,
      sessionId: sessionIdRef.current || "",
    };
  }

  function restoreState(s: SavedChatState) {
    setMode(s.mode);
    setIntent(s.intent);
    setStep(s.step);
    setMessages(s.messages);

    setCustomerName(s.customerName);
    setHelpSummary(s.helpSummary);

    setHaveVin(s.haveVin);
    setVinValue(s.vinValue);
    setHavePhotos(s.havePhotos);

    setFormsClaimType(s.formsClaimType);
    setFormsDeliveryChoice(s.formsDeliveryChoice);
    setFormsPdfIndex(s.formsPdfIndex);

    setAuthForm(s.authForm);
    setDtpForm(s.dtpForm);
    setDrForm(s.drForm);
    setEstForm(s.estForm);
    setInsuranceExplained(s.insuranceExplained);
    setAuthExplained(s.authExplained ?? false);
    setAuthInfoOpen(false);
    setInsuranceInfoOpen({ direction_to_pay: false, designated_representative: false, estimate_dismantling: false });

    setExtraNotes(s.extraNotes);
    setCallbackNumber(s.callbackNumber);

    setUploads(s.uploads);
    lastFilePickSigRef.current = s.lastFilePickSig;

    notifiedRef.current = s.notified;
    sessionIdRef.current = s.sessionId || makeSessionId();

    setInput("");
    setPendingMode(null);
  }

  function resetChat(nextMode: ConciergeMode = "default") {
    setMode(nextMode);

    setIntent("other");
    setStep(nextMode === "forms" ? "forms_claimType" : "help");
    setInput("");

    setCustomerName("");
    setHelpSummary("");
    setHaveVin("unknown");
    setVinValue("");
    setHavePhotos("unknown");

    setFormsClaimType(null);
    setFormsDeliveryChoice(null);
    setFormsPdfIndex(0);

    setAuthForm({
      fullName: "",
      address: "",
      townCity: "",
      zip: "",
      phone: "",
      email: "",
      year: "",
      make: "",
      model: "",
      plate: "",
      agree: false,
      signatureDataUrl: "",
    });

    setDtpForm({ date: yyyyMmDd(), fullName: "", insurerName: "", claimNumber: "", year: "", make: "", model: "", agree: false });
    setDrForm({ date: yyyyMmDd(), fullName: "", insurerName: "", claimNumber: "", year: "", make: "", model: "", plate: "", agree: false });
    setEstForm({ date: yyyyMmDd(), fullName: "", year: "", make: "", model: "", plate: "", agree: false, notRepairAgree: false });
    setInsuranceExplained({ direction_to_pay: false, designated_representative: false, estimate_dismantling: false });
    setInsuranceInfoOpen({ direction_to_pay: false, designated_representative: false, estimate_dismantling: false });
    setInsuranceSubmitting(false);
    setInsuranceError(null);
    setAuthError(null);
    setAuthSubmitting(false);
    setAuthExplained(false);
    setAuthInfoOpen(false);

    setUploads([]);
    setCallbackNumber("");
    setExtraNotes([]);
    lastFilePickSigRef.current = "";

    notifiedRef.current = false;
    sessionIdRef.current = makeSessionId();

    handoffStageRef.current = "idle";
    setHandoffStage("idle");

    setPendingMode(null);

    if (nextMode === "forms") {
      setMessages([
        {
          from: "bot",
          text: tr(
            "Let’s get your repair forms started.",
            "Vamos a comenzar tus formularios de reparación."
          ),
        },
        {
