  function looksLikeVin(text: string) {
    const cleaned = text.trim().toUpperCase().replace(/[^A-Z0-9]/g, "");
    if (cleaned.length !== 17) return false;
    return /^[A-Z0-9]{17}$/.test(cleaned);
  }

  function fileSignature(files: File[]) {
    return files.map((f) => `${f.name}|${f.size}|${f.lastModified}`).sort().join("::");
  }

  function onPickFiles(list: FileList | null) {
    if (!list || list.length === 0) return;

    const picked = Array.from(list);

    // Prevent duplicate "change" events from re-adding the same selection
    const sig = picked.map((f) => `${f.name}:${f.size}:${f.lastModified}`).join("|");
    if (sig && sig === lastFilePickSigRef.current) return;
    lastFilePickSigRef.current = sig;

    // Limits (keeps email payloads reasonable)
    const MAX_FILES = 10;
    const MAX_TOTAL_BYTES = 20 * 1024 * 1024; // ~20MB (Gmail limit is ~25MB)
    const existingTotal = uploads.reduce((sum, f) => sum + f.size, 0);

    let total = existingTotal;
    let remaining = Math.max(0, MAX_FILES - uploads.length);
    const willAdd: File[] = [];

    for (const f of picked) {
      if (remaining <= 0) break;
      if (total + f.size > MAX_TOTAL_BYTES) break;
      willAdd.push(f);
      total += f.size;
      remaining -= 1;
    }

    if (willAdd.length === 0) {
      addMessage("bot", "No more files can be added (limit reached).");
      return;
    }

    setUploads((prev) => [...prev, ...willAdd]);

    addMessage(
      "bot",
      `Got it — added ${willAdd.length} file${willAdd.length === 1 ? "" : "s"}.`
    );
  }

  function handleFilesChosen(e: ChangeEvent<HTMLInputElement>) {
    onPickFiles(e.target.files);
    // Allow selecting the same file again.
